---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import FilterBar from "../components/FilterBar.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ProjectModal from "../components/ProjectModal.astro";
import { getProjects, parseFilter, applyFilter } from "../lib/projects";

const projects = await getProjects();
const filter = parseFilter(Astro.url.searchParams);
const visible = applyFilter(projects, filter);

const year = new Date().getFullYear();
---

<Base>
  <Header count={visible.length} />
  <FilterBar projects={projects} active={filter} />

  <main id="main">
    <section
      class="max-w-7xl mx-auto px-5 sm:px-7"
      aria-labelledby="projectsHeading"
    >
      <div class="flex overflow-x-auto snap-x snap-mandatory scroll-smooth pb-8 -mx-5 px-5 sm:mx-0 sm:px-0 sm:grid sm:grid-cols-2 lg:grid-cols-3 gap-7 mt-10 no-scrollbar">
        {
          visible.length === 0 && (
            <div
              class="col-span-full py-32 text-center text-muted"
              role="status"
            >
              <h3 class="text-[17px] font-medium text-ink mb-1">
                Nenhum projeto encontrado
              </h3>
              <p class="font-mono text-[13px] mb-5">
                Nenhum item corresponde ao filtro "{filter.value}"
              </p>
              <a
                class="inline-flex text-[15px] font-medium underline underline-offset-4 text-ink hover:opacity-80 transition-opacity"
                href="/"
              >
                Limpar filtro
              </a>
            </div>
          )
        }
        {
          visible.map((project, index) => (
            <ProjectCard project={project} index={index} />
          ))
        }
      </div>
    </section>
  </main>

  <footer
    class="max-w-7xl mx-auto px-5 sm:px-7 py-10 text-[13px] text-muted text-center"
  >
    <span>&copy; {year} — LP Hub</span>
  </footer>

  <ProjectModal projects={projects} />
</Base>
