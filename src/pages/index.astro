---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import FilterBar from "../components/FilterBar.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ProjectModal from "../components/ProjectModal.astro";
import { getProjects, parseFilter, applyFilter } from "../lib/projects";
import { prepareProjectsForUI } from "../lib/view-models";
import ProjectModal from "../components/ProjectModal.astro";
import { getProjects, parseFilter, applyFilter } from "../lib/projects";
import { prepareProjectsForUI } from "../lib/view-models";

const rawProjects = await getProjects();
const filter = parseFilter(Astro.url.searchParams);
const visibleRaw = applyFilter(rawProjects, filter);

// Preparamos todos los proyectos crudos para el modal y los filtros
const allProjectsUI = await prepareProjectsForUI(rawProjects);

// Para las cards, usamos solo los visibles, pero ya procesados
const visible = allProjectsUI.filter(p => visibleRaw.some(vr => vr.id === p.id));

const year = new Date().getFullYear();
---

<Base>
  <Header count={visible.length} />
  <FilterBar projects={rawProjects} active={filter} />

  <main id="main">
    <section
      class="max-w-7xl mx-auto px-5 sm:px-7"
      aria-labelledby="projectsHeading"
    >
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mt-10">
        {
          visible.length === 0 && (
            <div
              class="col-span-full py-32 text-center text-muted border border-dashed border-line rounded-xl"
              role="status"
            >
              <h3 class="text-[17px] font-medium text-ink mb-1">
                Nenhum projeto encontrado
              </h3>
              <p class="font-mono text-[13px] mb-5 opacity-60">
                Nenhum item corresponde ao filtro "{filter.value}"
              </p>
              <a
                class="inline-flex h-10 items-center px-6 bg-ink text-bg rounded-pill text-[12px] font-mono font-bold uppercase tracking-widest hover:scale-105 transition-transform"
                href="/"
              >
                Limpar filtro
              </a>
            </div>
          )
        }
        {
          visible.map((project, index) => (
            <ProjectCard project={project} index={index} />
          ))
        }
      </div>
    </section>
  </main>

  <footer
    class="max-w-7xl mx-auto px-5 sm:px-7 py-10 text-[13px] text-muted text-center"
  >
    <span>&copy; {year} — LP Hub</span>
  </footer>

  <ProjectModal projects={rawProjects} />
</Base>
