---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import FilterBar from "../components/FilterBar.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ProjectModal from "../components/ProjectModal.astro";
import { getProjects, parseFilter, applyFilter } from "../lib/projects";
import { prepareProjectsForUI } from "../lib/view-models";

const rawProjects = await getProjects();
const filter = parseFilter(Astro.url.searchParams);
const visibleRaw = applyFilter(rawProjects, filter);

const allProjectsUI = await prepareProjectsForUI(rawProjects);
const visible = allProjectsUI.filter(p => visibleRaw.some(vr => vr.id === p.id));

const year = new Date().getFullYear();
---

<Base>
  <Header count={visible.length} />
  <FilterBar projects={rawProjects} active={filter} />

  <main id="main" class="flex-1">
    <section
      aria-labelledby="projectsHeading"
    >
      {visible.length === 0 ? (
        <div class="max-w-7xl mx-auto px-5 sm:px-7 mt-10">
          <div
            class="py-32 text-center text-muted border border-dashed border-line rounded-xl"
            role="status"
          >
            <h3 class="text-[17px] font-medium text-ink mb-1">
              Nenhum projeto encontrado
            </h3>
          </div>
        </div>
      ) : (
        <>
          {/* ── Projects Grid ─────────────────────────────────────────────
              Responsive grid: 2 columns on mobile, 3 on lg, 4 on xl.
          ── */}
          <div class="grid max-w-7xl mx-auto px-4 sm:px-7 grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 sm:gap-6 mt-8 sm:mt-10">
            {visible.map((project, index) => (
              <ProjectCard project={project} index={index} />
            ))}
          </div>
        </>
      )}
    </section>
  </main>

  <footer
    class="max-w-7xl mx-auto px-5 sm:px-7 py-10 text-[13px] text-muted text-center"
  >
    <span>&copy; {year} Soluções Digitais</span>
  </footer>

  <ProjectModal projects={rawProjects} />
</Base>
