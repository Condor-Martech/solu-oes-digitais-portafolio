---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import FilterBar from '../components/FilterBar.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProjectModal from '../components/ProjectModal.astro';
import { getProjects, parseFilter, applyFilter } from '../lib/projects';

const projects = await getProjects();
const filter = parseFilter(Astro.url.searchParams);
const visible = applyFilter(projects, filter);

const year = new Date().getFullYear();
---

<Base>
  <Header count={visible.length} />
  <FilterBar projects={projects} active={filter} />

  <main id="main">
    <section class="wrap hero">
      <span class="hero-kicker">Coleção 2020 — 2026</span>
      <h1>
        Sites e landing pages<br />
        <em>produzidos pelo time.</em>
      </h1>
      <p>
        Seleção de projetos entregues para o Grupo Condor e parceiros — e-commerce,
        portais institucionais, hotsites promocionais e campanhas de temporada.
      </p>
    </section>

    <section class="wrap" aria-labelledby="projectsHeading">
      <h2 class="sr-only" id="projectsHeading">Projetos</h2>
      <div class="grid">
        {visible.length === 0 && (
          <div class="empty" role="status">
            <h3 class="empty-title">Nenhum projeto encontrado</h3>
            <p class="empty-sub">
              Nenhum item corresponde ao filtro "{filter.value}"
            </p>
            <a class="empty-action" href="/">Limpar filtro</a>
          </div>
        )}
        {visible.map((project, index) => (
          <ProjectCard project={project} index={index} />
        ))}
      </div>
    </section>
  </main>

  <footer class="wrap site-footer">
    <span>&copy; {year} — LP Hub</span>
    <span>Feito em Astro + Tailwind</span>
  </footer>

  <ProjectModal projects={projects} />
</Base>
