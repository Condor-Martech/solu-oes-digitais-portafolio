---
interface Props {
  id: string;
  side?: 'right' | 'left';
}

const { id, side = 'right' } = Astro.props;
---

<lp-drawer 
  id={id} 
  class="fixed inset-0 z-[60] pointer-events-none group invisible [&.open]:visible"
>
  <!-- Backdrop -->
  <div class="backdrop absolute inset-0 bg-ink/30 opacity-0 transition-opacity duration-300 ease-in-out group-[.open]:opacity-100 group-[.open]:pointer-events-auto"></div>
  
  <!-- Content Panel -->
  <div class:list={[
    "panel absolute top-0 h-full w-[85%] max-w-[320px] bg-surface border-line flex flex-col transition-transform duration-300 ease-in-out group-[.open]:translate-x-0 group-[.open]:pointer-events-auto shadow-xl",
    side === 'right' ? "right-0 translate-x-full border-l-[0.5px]" : "left-0 -translate-x-full border-r-[0.5px]"
  ]}>
    <slot />
  </div>
</lp-drawer>

<script>
  class LPDrawer extends HTMLElement {
    constructor() {
      super();
      const backdrop = this.querySelector('.backdrop');
      const closeBtns = this.querySelectorAll('[data-drawer-close]');

      backdrop?.addEventListener('click', () => this.close());
      closeBtns.forEach(btn => btn.addEventListener('click', () => this.close()));

      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.classList.contains('open')) this.close();
      });
    }

    open() {
      const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
      document.body.style.overflow = 'hidden';
      document.body.style.paddingRight = `${scrollbarWidth}px`;
      
      this.classList.add('open');
    }

    close() {
      this.classList.remove('open');
      
      // Wait for transition before unlocking scroll
      setTimeout(() => {
        document.body.style.overflow = '';
        document.body.style.paddingRight = '';
      }, 300);
    }
  }

  customElements.define('lp-drawer', LPDrawer);
</script>
