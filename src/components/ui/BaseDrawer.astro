---
interface Props {
  id: string;
  side?: 'right' | 'left';
}

const { id, side = 'right' } = Astro.props;
---

<lp-drawer 
  id={id} 
  class="fixed inset-0 z-[60] pointer-events-none group hidden [&.open]:block [&.open]:pointer-events-auto"
>
  <!-- Backdrop -->
  <div class="backdrop absolute inset-0 bg-ink/30 backdrop-blur-sm opacity-0 transition-opacity duration-400 group-[.open]:opacity-100"></div>
  
  <!-- Content Panel -->
  <div class:list={[
    "panel absolute top-0 h-full w-[85%] max-w-[340px] bg-surface border-line flex flex-col transition-transform duration-500 ease-out group-[.open]:translate-x-0",
    side === 'right' ? "right-0 translate-x-full border-l-[0.5px]" : "left-0 -translate-x-full border-r-[0.5px]"
  ]}>
    <slot />
  </div>
</lp-drawer>

<script>
  class LPDrawer extends HTMLElement {
    private scrollY = 0;

    constructor() {
      super();
      const backdrop = this.querySelector('.backdrop');
      const closeBtns = this.querySelectorAll('[data-drawer-close]');

      backdrop?.addEventListener('click', () => this.close());
      closeBtns.forEach(btn => btn.addEventListener('click', () => this.close()));

      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.classList.contains('open')) this.close();
      });
    }

    open() {
      this.hidden = false;
      this.lockScroll();
      requestAnimationFrame(() => this.classList.add('open'));
    }

    close() {
      this.classList.remove('open');
      this.unlockScroll();
      setTimeout(() => {
        this.hidden = true;
      }, 500);
    }

    private lockScroll() {
      this.scrollY = window.scrollY;
      document.body.style.cssText = `position: fixed; top: -${this.scrollY}px; width: 100%;`;
    }

    private unlockScroll() {
      document.body.style.cssText = '';
      window.scrollTo(0, this.scrollY);
    }
  }

  customElements.define('lp-drawer', LPDrawer);
</script>
