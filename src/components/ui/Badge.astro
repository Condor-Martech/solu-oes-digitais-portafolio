---
import { getBrandColor, getBadgeThemeClasses } from '../../lib/projects';

interface Props {
  text: string;
  color?: string; // Si se pasa, se usa directamente. Si no, se calcula por el texto.
  className?: string;
}

const { text, color, className = "" } = Astro.props;

// Intentamos obtener el color basado en el texto si no se provee uno
const themeColor = color || getBrandColor(text);
const themeClasses = getBadgeThemeClasses(themeColor as any);
---

<span class:list={[
  "inline-flex items-center px-2 py-0.5 rounded-sm text-[10px] sm:text-[11px] font-medium font-mono uppercase tracking-[0.05em] border-[0.5px] border-line border-opacity-10 transition-colors",
  themeClasses,
  className
]}>
  {text}
</span>
