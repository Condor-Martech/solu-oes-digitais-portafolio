---
export interface Props {
  name: 'close' | 'close-modal' | 'menu';
  class?: string;
  width?: string | number;
  height?: string | number;
}

const { name, class: className = '', width = '24', height = '24' } = Astro.props;

// Diccionario centralizado de vectores (Paths) con sus viewBox específicos
const ICONS = {
  close: { 
    viewBox: '0 0 24 24', 
    svg: `<line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />` 
  },
  'close-modal': { 
    viewBox: '0 0 14 14', 
    svg: `<path d="M1 1L13 13M13 1L1 13" />` 
  },
  menu: { 
    viewBox: '0 0 24 24', 
    svg: `<line x1="4" y1="12" x2="20" y2="12" /><line x1="4" y1="6" x2="20" y2="6" /><line x1="4" y1="18" x2="20" y2="18" />` 
  }
};

const iconData = ICONS[name];
---

{iconData && (
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    viewBox={iconData.viewBox} 
    fill="none" 
    stroke="currentColor" 
    stroke-width="2" 
    stroke-linecap="round"
    stroke-linejoin="round"
    width={width}
    height={height}
    class={className}
    set:html={iconData.svg}
  />
)}
