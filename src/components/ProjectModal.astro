---
import BaseModal from './ui/BaseModal.astro';
import Icon from './ui/Icon.astro';
import { prepareProjectsForUI } from '../lib/view-models';
import type { Project } from '../types';

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
const modalDataList = await prepareProjectsForUI(projects);
---

<BaseModal id="projectModal">
  <!-- Lado Izquierdo: Imagen -->
  <div class="w-full h-48 sm:h-64 lg:h-auto lg:w-[58%] relative overflow-hidden bg-line/5 border-b-[0.5px] lg:border-b-0 lg:border-r border-line">
    <img class="w-full h-full object-cover object-top transition-transform duration-[1200ms] ease-out" id="modalImg" alt="" />
  </div>

  <!-- Lado Derecho: Info -->
  <div class="flex-1 flex flex-col h-full bg-surface relative overflow-hidden">
    <!-- Navbar interna -->
    <div class="flex items-center justify-between px-6 py-4 border-b-[0.5px] border-line/10 sticky top-0 z-20 bg-surface/80 backdrop-blur-md">
      <div class="flex items-center gap-3">
        <span class="font-mono text-[11px] font-medium uppercase tracking-[0.1em] text-muted/80" id="modalCrumb">Projeto</span>
        <span class="w-[1px] h-3 bg-line/20"></span>
        <div class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full" id="modalStatusDot"></span>
          <span class="font-mono text-[10px] font-bold uppercase tracking-wider text-ink/60" id="modalStatusLabel"></span>
        </div>
      </div>
      <button 
        class="w-9 h-9 flex items-center justify-center rounded-full border border-line/20 text-muted hover:text-ink hover:bg-line/5 transition-all outline-none focus-visible:ring-2 focus-visible:ring-ink" 
        data-modal-close
        aria-label="Fechar"
      >
        <Icon name="close-modal" width="14" height="14" />
      </button>
    </div>

    <!-- Contenido -->
    <div class="flex-1 overflow-y-auto p-6 sm:p-10 lg:pt-8 flex flex-col gap-6 custom-scrollbar">
      <div class="flex flex-col gap-3">
        <h2 class="m-0 text-[28px] sm:text-[34px] font-medium tracking-tight leading-[1.1] text-ink" id="modalTitle"></h2>
        <div class="flex flex-wrap gap-2" id="modalTags"></div>
      </div>
      
      <div class="flex flex-col gap-5 text-[16px] leading-[1.7] text-ink-2" id="modalDesc"></div>

      <div class="mt-auto pt-4 flex flex-col sm:flex-row items-center gap-4">
        <a class="inline-flex items-center justify-center h-[46px] px-8 bg-ink text-bg font-mono text-[12px] font-bold tracking-widest uppercase rounded-pill transition-all hover:shadow-premium hover:-translate-y-0.5 hidden [&.active]:inline-flex w-full sm:w-max" id="modalLink" href="#" target="_blank" rel="noopener noreferrer">Visitar site</a>
      </div>
    </div>
  </div>
</BaseModal>

<script>
  import { initProjectModal } from '../scripts/modal';
  
  // Recuperamos los datos pasados desde el servidor
  // Nota: En una app real, esto podría venir de una API, pero para mantener el bundle pequeño
  // y la velocidad de carga, lo inyectamos una sola vez.
  const dataEl = document.getElementById('project-modal-data');
  if (dataEl) {
    const modalData = JSON.parse(dataEl.textContent || '{}');
    initProjectModal(modalData);
  }
</script>

<script is:inline define:vars={{ modalDataList }}>
  // Inyectamos los datos en un script de solo lectura para el cliente
  (function() {
    const data = Object.fromEntries(modalDataList.map(p => [p.id, p]));
    const script = document.createElement('script');
    script.type = 'application/json';
    script.id = 'project-modal-data';
    script.textContent = JSON.stringify(data);
    document.body.appendChild(script);
  })();
</script>
