---
import type { UIProject } from '../types';
import { getCardDelay } from '../lib/ui-helpers';
import Badge from './ui/Badge.astro';
import { Image } from 'astro:assets';

interface Props {
  project: UIProject;
  index?: number;
}

const { project, index = 0 } = Astro.props;
const delay = getCardDelay(index);
---

<article 
  class="group relative flex flex-col bg-surface border-[0.5px] border-line rounded-xl overflow-hidden hover:border-line-strong transition-all duration-500 shadow-sm hover:shadow-premium hover:-translate-y-1.5 animate-rise opacity-0 h-full cursor-pointer"
  style={`animation-delay: ${delay}ms; animation-fill-mode: forwards;`}
  data-open-project={project.id}
>
  <!-- Image Section -->
  <div class="relative aspect-[4/3] overflow-hidden isolate">
    <div class="absolute inset-0 transition-transform duration-[1.5s] ease-custom group-hover:scale-110 bg-line/5 z-0">
      {project.image ? (
        <Image 
          src={project.image} 
          alt={project.title}
          width={800}
          height={600}
          class="w-full h-full object-cover object-top opacity-0 transition-opacity duration-700"
          onload="this.classList.remove('opacity-0')"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center border-b border-line/10 bg-bg/50">
          <span class="font-mono text-[9px] uppercase tracking-[0.2em] opacity-20">Preview N/A</span>
        </div>
      )}
    </div>
    
    <!-- Hover Overlay -->
    <div class="absolute inset-0 bg-ink/20 opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center backdrop-blur-[2px] z-30">
      <button 
        class="px-6 py-2.5 bg-surface border border-line rounded-md text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-ink shadow-2xl translate-y-4 group-hover:translate-y-0 transition-all duration-500 hover:bg-ink hover:text-bg hover:border-ink active:scale-95"
        data-open-project={project.id}
      >
        Ver Detalhes
      </button>
    </div>
  </div>

  <!-- Content Section -->
  <div class="p-2.5 sm:p-4 flex flex-col gap-2 flex-1">
    <h3 class="m-0 text-[14px] sm:text-[16px] font-medium tracking-tight text-ink leading-snug line-clamp-2 group-hover:text-ink transition-colors">
      {project.title}
    </h3>
    
    <div class="flex flex-wrap gap-1.5 mt-auto pt-1">
      <Badge text={project.company} className={`opacity-80 text-[9px] sm:text-[10px] ${project.theme.company}`} />
      {project.theme.types.slice(0, 3).map((t) => (
        <Badge text={t.label} className={`opacity-70 text-[9px] sm:text-[10px] ${t.classes}`} />
      ))}
    </div>
  </div>

  <!-- Subtle glow on hover -->
  <div class="absolute inset-0 border border-transparent group-hover:border-ink/5 rounded-md pointer-events-none transition-all duration-500 shadow-none group-hover:shadow-[0_0_40px_rgba(0,0,0,0.05)]"></div>
</article>
