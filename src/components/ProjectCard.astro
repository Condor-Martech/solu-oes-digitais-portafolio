---
import type { Project } from '../lib/projects';
import { firstParagraph } from '../lib/projects';
import Tag from './Tag.astro';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
const delay = Math.min(index * 55, 420);
const hasImage = Boolean(project.image);
---

<article class="snap-center shrink-0 w-[85vw] sm:w-auto flex flex-col border-[0.5px] border-line rounded-[18px] bg-surface overflow-hidden opacity-0 animate-[rise_0.8s_both] isolate shadow-[0_4px_20px_-4px_rgba(0,0,0,0.1)] hover:shadow-[var(--shadow-premium)] hover:-translate-y-2 transition-all duration-500 ease-custom group/card" style={`animation-delay:${delay}ms`} data-project-id={project.id}>
  <div class="relative aspect-[16/9] bg-[#ECEBE7] overflow-hidden group/cover">
    {/* Badge de Status */}
    <div class="absolute top-3 right-3 z-30 flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-surface/90 backdrop-blur-md border border-line/10 shadow-sm">
      <span class={`w-2 h-2 rounded-full ${project.status === 'No ar' ? 'bg-green-500 animate-pulse shadow-[0_0_8px_rgba(34,197,94,0.6)]' : 'bg-red-500'}`}></span>
      <span class="text-[10px] font-bold uppercase tracking-wider text-ink/80">{project.status}</span>
    </div>

    {hasImage && (
      <img 
        class={`w-full h-full object-cover object-top transition-all duration-700 ease-out group-hover/card:scale-[1.03] ${project.status === 'Fora do ar' ? 'grayscale opacity-80 contrast-75' : ''}`} 
        src={project.image} 
        alt="" 
        loading="lazy" 
        data-fallback 
      />
    )}
    {!hasImage && (
      <div class="absolute inset-0 flex items-center justify-center font-mono text-[13px] text-muted uppercase tracking-widest transition-transform duration-700 group-hover/card:scale-[1.03]">sem captura</div>
    )}
    <div class="absolute inset-0 flex items-center justify-center bg-ink/10 opacity-0 transition-opacity duration-400 pointer-events-none group-hover/card:opacity-100 group-hover/card:backdrop-blur-[2px]" aria-hidden="true">
      <span class="bg-surface/95 backdrop-blur-md px-[16px] py-2.5 rounded-pill text-[13px] font-semibold text-ink shadow-lg shadow-ink/10 translate-y-4 group-hover/card:translate-y-0 transition-transform duration-400 ease-out">Ver detalles</span>
    </div>
  </div>

  <div class="p-5 xl:p-4 flex flex-col flex-1 gap-4">
    <div class="flex items-start justify-between gap-4">
      <h3 class="m-0 flex-1 min-w-0">
        <button
          class="text-left text-[17px] sm:text-[19px] xl:text-[17px] font-medium leading-[1.2] tracking-tight hover:opacity-75 transition-opacity outline-none focus-visible:ring-2 focus-visible:ring-ink focus-visible:ring-offset-2 rounded-sm before:content-[''] before:absolute before:inset-0 before:z-10"
          type="button"
          data-open-project={project.id}
          aria-label={`Abrir detalhes de ${project.title}`}
        >
          {project.title}
        </button>
      </h3>
      <a
        class="shrink-0 inline-flex text-[13px] font-medium text-muted underline underline-offset-4 hover:text-ink transition-colors relative z-20"
        href={project.link}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Visitar ${project.title} (abre em nova aba)`}
      >
        Visitar
      </a>
    </div>

    {project.desc && (
      <p class="m-0 text-[14px] leading-relaxed text-muted line-clamp-3">{firstParagraph(project.desc)}</p>
    )}

    <div class="flex flex-wrap gap-2 mt-auto relative z-20" aria-label="Tags">
      <Tag label={project.company} />
      <Tag label={project.production} />
      {project.type?.map((t) => <Tag label={t} />)}
    </div>
  </div>
</article>
