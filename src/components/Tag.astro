---
import { getBrandColor, getBadgeThemeClasses } from '../lib/projects';

interface Props {
  label: string;
}

const { label } = Astro.props;
const themeClass = getBadgeThemeClasses(getBrandColor(label));
---

<span
  class={`inline-flex items-center px-1.5 py-0.5 rounded-sm text-[10px] sm:text-[11px] font-medium font-mono uppercase tracking-[0.05em] border-[0.5px] border-line border-opacity-10 ${themeClass}`}
>
  {label}
</span>
