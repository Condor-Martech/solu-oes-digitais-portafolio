---
import type { Project, ActiveFilter } from '../lib/projects';
import {
  uniqueCompanies,
  countForCompany,
  getBrandColor,
  getFilterThemeClasses
} from '../lib/projects';

interface Props {
  projects: Project[];
  active: ActiveFilter;
}

const { projects, active } = Astro.props;

const companies = uniqueCompanies(projects);

function hrefFor(group: 'all' | 'company' | 'production', value?: string): string {
  if (group === 'all') return '/';
  const params = new URLSearchParams();
  params.set(group, value ?? '');
  return `/?${params.toString()}`;
}

function isActive(group: 'all' | 'company', value?: string): boolean {
  if (group === 'all') return active.group === 'all';
  return active.group === group && active.value === value;
}
---

<div class="border-b-[0.5px] border-line bg-surface/90 backdrop-blur-md sticky top-[60px] sm:top-[64px] z-30">
  <div class="max-w-7xl mx-auto px-5 sm:px-7 py-2 sm:py-3 flex items-center justify-between sm:justify-start gap-4">
    
    <!-- Mobile Filter Summary & Trigger -->
    <div class="flex sm:hidden items-center justify-between w-full">
      <div class="flex items-center gap-2">
        <span class="text-[11px] font-mono uppercase tracking-wider text-muted/60">Marca</span>
        <span class="text-[13px] font-medium text-ink">{active.value === 'Tudo' ? 'Todas' : active.value}</span>
      </div>
      <button 
        id="filterTrigger"
        class="inline-flex items-center justify-center w-9 h-9 border border-line bg-surface rounded-xl text-ink transition-all active:scale-90"
        type="button"
        aria-label="Abrir filtros"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
      </button>
    </div>

    <!-- Desktop Filter List -->
    <nav class="hidden sm:flex flex-wrap gap-2.5 sm:gap-3" aria-label="Filtros por projeto">
      <a
        class={`group inline-flex items-center gap-1.5 py-1.5 px-3.5 sm:py-2 sm:px-4 border rounded-pill text-[11px] sm:text-[13px] font-medium font-mono uppercase tracking-[0.03em] transition-all duration-300 outline-none focus-visible:ring-1 ${getFilterThemeClasses('default')} hover:scale-[1.03] active:scale-95`}
        href={hrefFor('all')}
        aria-pressed={isActive('all') ? 'true' : 'false'}
      >
        Tudo
        <span class="opacity-40 text-[10px] sm:text-[11px] group-aria-[pressed=true]:opacity-80" aria-hidden="true">{projects.length}</span>
      </a>

      {companies.map((c) => {
        const themeClass = getFilterThemeClasses(getBrandColor(c));
        return (
          <a
            class={`group inline-flex items-center gap-1.5 py-1.5 px-3.5 sm:py-2 sm:px-4 border rounded-pill text-[11px] sm:text-[13px] font-medium font-mono uppercase tracking-[0.03em] transition-all duration-300 outline-none focus-visible:ring-1 ${themeClass} hover:scale-[1.03] active:scale-95`}
            href={hrefFor('company', c)}
            aria-pressed={isActive('company', c) ? 'true' : 'false'}
          >
            {c}
            <span class="opacity-40 text-[10px] sm:text-[11px] group-aria-[pressed=true]:opacity-80" aria-hidden="true">{countForCompany(projects, c)}</span>
          </a>
        );
      })}
    </nav>
  </div>
</div>

<!-- Mobile Filter Drawer -->
<div 
  id="filterDrawer" 
  class="fixed inset-0 z-[60] opacity-0 pointer-events-none transition-all duration-400 group/drawer"
  hidden
>
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-ink/30 backdrop-blur-sm transition-opacity duration-400 opacity-0 group-[.open]/drawer:opacity-100" id="drawerBackdrop"></div>
  
  <!-- Content Panel -->
  <div class="absolute top-0 right-0 w-[85%] max-w-[340px] h-full bg-surface border-l-[0.5px] border-line flex flex-col translate-x-full transition-transform duration-500 ease-out group-[.open]/drawer:translate-x-0">
    <div class="flex items-center justify-between p-6 border-b-[0.5px] border-line">
      <h2 class="text-[17px] font-medium tracking-tight">Marcas</h2>
      <button id="drawerClose" class="w-8 h-8 flex items-center justify-center rounded-full border-[0.5px] border-line text-muted/60 transition-colors hover:text-ink">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    
    <div class="flex-1 overflow-y-auto px-6 py-4">
      <div class="flex flex-col border-t border-line">
        <a
          class={`group flex items-center justify-between py-3.5 border-b border-line text-[12px] font-mono uppercase tracking-wider transition-all ${isActive('all') ? 'text-ink' : 'text-muted hover:text-ink'}`}
          href={hrefFor('all')}
        >
          <div class="flex items-center gap-3">
            <span class={`w-1.5 h-1.5 rounded-full transition-all ${isActive('all') ? 'bg-ink scale-110' : 'bg-transparent'}`}></span>
            <span>Tudo</span>
          </div>
          <span class="opacity-40 text-[11px]">{projects.length}</span>
        </a>

        {companies.map((c) => {
          return (
            <a
              class={`group flex items-center justify-between py-3.5 border-b border-line text-[12px] font-mono uppercase tracking-wider transition-all ${isActive('company', c) ? 'text-ink' : 'text-muted hover:text-ink'}`}
              href={hrefFor('company', c)}
            >
              <div class="flex items-center gap-3">
                <span class={`w-1.5 h-1.5 rounded-full transition-all ${isActive('company', c) ? 'bg-ink scale-110' : 'bg-transparent'}`}></span>
                <span>{c}</span>
              </div>
              <span class="opacity-40 text-[11px]">{countForCompany(projects, c)}</span>
            </a>
          );
        })}
      </div>
    </div>
    
    <div class="p-5 border-t-[0.5px] border-line bg-bg/30 mt-auto">
      <div class="flex items-center gap-2 text-[11px] text-muted/80 font-mono uppercase tracking-wide">
        <span class="w-1.5 h-1.5 rounded-full bg-ink/20 animate-pulse"></span>
        Select to filter
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const trigger = document.getElementById('filterTrigger');
    const drawer = document.getElementById('filterDrawer');
    const close = document.getElementById('drawerClose');
    const backdrop = document.getElementById('drawerBackdrop');
    
    if (!trigger || !drawer) return;

    function open() {
      drawer.hidden = false;
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        drawer.classList.add('open');
        drawer.style.opacity = '1';
        drawer.style.pointerEvents = 'auto';
      });
    }

    function closeDrawer() {
      drawer.classList.remove('open');
      drawer.style.opacity = '0';
      drawer.style.pointerEvents = 'none';
      document.body.style.overflow = '';
      setTimeout(() => {
        drawer.hidden = true;
      }, 400);
    }

    trigger.addEventListener('click', open);
    close.addEventListener('click', closeDrawer);
    backdrop.addEventListener('click', closeDrawer);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !drawer.hidden) closeDrawer();
    });
  })();
</script>
