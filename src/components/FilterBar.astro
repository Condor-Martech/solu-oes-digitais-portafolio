---
import type { Project, ActiveFilter } from '../types';
import { prepareFilterData } from '../lib/view-models';
import { buildFilterLinks } from "../lib/ui-helpers";
import BaseDrawer from "./ui/BaseDrawer.astro";
import Badge from "./ui/Badge.astro";
import Icon from "./ui/Icon.astro";

interface Props {
  projects: Project[];
  active: ActiveFilter;
}

const { projects, active } = Astro.props;

// Preparamos los datos
const rawFilterCompanies = prepareFilterData(projects);
const filterLinks = buildFilterLinks(rawFilterCompanies, active);
---

<div
  class="border-b-[0.5px] border-line bg-surface/90 backdrop-blur-md sticky top-[52px] sm:top-[64px] z-30"
>
  <div
    class="max-w-7xl mx-auto px-5 sm:px-7 py-2 sm:py-3 flex items-center justify-between sm:justify-start gap-4"
  >
    <!-- Mobile Filter Summary -->
    <div class="flex sm:hidden items-center justify-between w-full">
      <div class="flex items-center gap-2">
        <span
          class="text-[11px] font-mono uppercase tracking-wider text-muted/60"
          >Categoria</span
        >
        <span class="text-[13px] font-medium text-ink"
          >{active.value === "Tudo" ? "Todas" : active.value}</span
        >
      </div>
      <button
        id="filterBtn"
        class="inline-flex items-center justify-center w-9 h-9 border border-line bg-surface rounded-md text-ink active:scale-90 transition-transform"
        aria-label="Abrir filtros"
      >
        <Icon name="menu" width="20" height="20" />
      </button>
    </div>

    <!-- Desktop Filter List -->
    <nav class="hidden sm:flex flex-wrap gap-2.5" aria-label="Filtros">
      <a
        href={filterLinks.all.href}
        class="hover:scale-[1.03] transition-transform"
        aria-pressed={filterLinks.all.isActive ? "true" : "false"}
      >
        <Badge
          text={filterLinks.all.label}
          className={filterLinks.all.isActive
            ? "ring-1 ring-ink/20"
            : "opacity-70"}
        />
      </a>
      {
        filterLinks.companies.map((c) => (
          <a
            href={c.href}
            class="hover:scale-[1.03] transition-transform"
            aria-pressed={c.isActive ? "true" : "false"}
          >
            <Badge
              text={c.label}
              className={c.isActive ? "ring-1 ring-ink/20" : "opacity-70"}
            />
          </a>
        ))
      }
    </nav>
  </div>
</div>

<BaseDrawer id="filterDrawer">
  <div
    class="flex items-center justify-between p-6 border-b-[0.5px] border-line bg-surface/50 backdrop-blur-sm sticky top-0 z-10"
  >
    <div class="flex flex-col gap-0.5">
      <h2 class="text-[17px] font-medium tracking-tight text-ink">Categorias</h2>
    </div>
    <button
      data-drawer-close
      class="w-9 h-9 flex items-center justify-center rounded-full border-[0.5px] border-line text-muted/60 hover:text-ink hover:border-line-strong transition-colors"
    >
      <Icon name="close" width="20" height="20" />
    </button>
  </div>

  <div class="flex-1 overflow-y-auto px-6 py-6 flex flex-col gap-2">
    <a
      href={filterLinks.all.href}
      class="flex items-center justify-between p-3 border rounded-md bg-line/5"
    >
      <span class="text-[13px] font-medium">Todas as Categorias</span>
      <span class="text-[11px] font-mono opacity-50">{projects.length}</span>
    </a>
    {
      filterLinks.companies.map((c) => (
        <a
          href={c.href}
          class:list={[
            "flex items-center justify-between p-3 border rounded-md transition-all",
            c.isActive ? "border-ink bg-ink/5" : "border-line",
          ]}
        >
          <div class="flex items-center gap-3">
            <div
              class:list={[
                "w-2 h-2 rounded-full",
                c.isActive ? "bg-ink" : "bg-line",
              ]}
            />
            <span class="text-[13px] font-medium">{c.label}</span>
          </div>
          <span class="text-[11px] font-mono opacity-50">{c.count}</span>
        </a>
      ))
    }
  </div>
</BaseDrawer>

<script>
  import { initFilterBar } from "../scripts/filter";
  initFilterBar();
</script>
